{
  "manifest_version": 3,
  "name": "Payload Inspector Pro",
  "version": "1.0.3",
  "description": "Fångar utgående payloads, grupperar per domän och använder ett mjukt gränssnitt.",
  "permissions": [
    "webRequest",
    "sidePanel",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Open Inspector"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}